<cg>

  <inverse>

    <kBT>2.479</kBT>

    <method>re</method>

    <scale>0.1</scale>

    <iterations_max>200</iterations_max>

    <program>gromacs</program>

    <map>
      coarse_grained_cellulose_mapping_for_coarse_grained.xml
    </map>

    <filelist>
      table.xvg
      coarse_grained_cellulose.gro
      coarse_grained_cellulose.ndx
      coarse_grained_cellulose.itp
      coarse_grained_cellulose.top
      coarse_grained_cellulose_posre.itp
      coarse_grained_cellulose_equilibrium.mdp
      table_b1.xvg
      table_b2.xvg
      table_b3.xvg
      table_a1.xvg
      table_a2.xvg
      table_a3.xvg
      table_a4.xvg
      table_a5.xvg
      table_a6.xvg
      table_d1.xvg
      table_d2.xvg
      table_d3.xvg
    </filelist>

    <gromacs>
      <table_bins>0.002</table_bins>
      <table_end>2.0</table_end>
      <conf>coarse_grained_cellulose.gro</conf>
      <index>coarse_grained_cellulose.ndx</index>
      <topol_in>coarse_grained_cellulose.top</topol_in>
      <mdp>coarse_grained_cellulose_equilibrium.mdp</mdp>
      <topol>coarse_grained_cellulose_equilibrium.tpr</topol>
      <grompp>
        <opts>-r coarse_grained_cellulose.gro</opts>
      </grompp>
      <mdrun>
        <opts>-ntmpi 4 -ntomp 1 -rdd 2.5 -v</opts>
      </mdrun>
    </gromacs>

    <simulation>
      <tasks>4</tasks>
    </simulation>

  </inverse>

  <non-bonded>
    <name>nonbonded11</name>
    <type1>CL1</type1>
    <type2>CL1</type2>
    <min>0.20</min>
    <max>1.50</max>
    <step>0.01</step>
    <inverse>
      <target>nonbonded11.dist.new</target>
      <gromacs>
        <table>table_CL1_CL1.xvg</table>
      </gromacs>
      <post_update>extrapolate</post_update>
      <post_update>smooth</post_update>
    </inverse>
    <re>
      <function>cbspl</function>
      <cbspl>
        <nknots>10</nknots>
      </cbspl>
    </re>
  </non-bonded>
  <non-bonded>
    <name>nonbonded12</name>
    <type1>CL1</type1>
    <type2>CL2</type2>
    <min>0.20</min>
